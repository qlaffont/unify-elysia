{
  "name": "unify-elysia",
  "version": "1.1.44",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "bunup",
    "prepare": "bunup",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "lint": "tsc --noEmit && oxlint src",
    "format": "oxfmt src"
  },
  "husky": {
    "hooks": {
      "pre-commit": "oxlint src && oxfmt --check src"
    }
  },
  "peerDependencies": {
    "elysia": "latest"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "unify-errors": "^1.3.91"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.8",
    "bun-types": "latest",
    "bunup": "latest",
    "elysia": "^1.4.27",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.14.0"
}